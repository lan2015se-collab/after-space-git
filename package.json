{
  "name": "after-space",
  "version": "1.3.0",
  "description": "AFTER SPACE installer build source",
  "main": "main.js",
  "author": "Codex",
  "license": "MIT",
  "scripts": {
    "build": "electron-builder --win nsis",
    "dist": "electron-builder --win nsis",
    "start": "electron ."
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.afterspace.game",
    "productName": "AFTER SPACE",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "*.js",
      "*.html",
      "*.css",
      "assets/**/*",
      "build/**/*",
      "node_modules/three/**/*"
    ],
    "icon": "build/app-icon.ico",
    "win": {
      "icon": "build/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "AFTER SPACE",
      "installerIcon": "build/app-icon.ico",
      "uninstallerIcon": "build/app-icon.ico",
      "installerHeaderIcon": "build/app-icon.ico",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp"
    }
  }
}
