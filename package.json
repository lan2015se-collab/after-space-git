{
  "name": "after-space",
  "version": "1.1.0",
  "description": "AFTER SPACE installer build source",
  "main": "main.js",
  "author": "Codex",
  "license": "MIT",
  "scripts": {
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.afterspace.game",
    "productName": "AFTER SPACE",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "*.js",
      "*.html",
      "*.css",
      "node_modules/three/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "AFTER SPACE"
    }
  }
}
